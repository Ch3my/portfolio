---
---
<div id="scattered-squares" class="absolute inset-0 pointer-events-none overflow-hidden" style="z-index: 0;">
	<svg
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 1400 750"
		preserveAspectRatio="xMidYMin slice"
		class="w-full h-full"
	>
		<!-- Top-left cluster -->
		<rect class="sq" x="0" y="0" width="78" height="78" rx="6" />
		<rect class="sq" x="80" y="0" width="78" height="78" rx="6" />
		<rect class="sq" x="0" y="80" width="78" height="78" rx="6" />
		<rect class="sq" x="80" y="80" width="78" height="78" rx="6" />
		<rect class="sq" x="0" y="160" width="78" height="78" rx="6" />

		<!-- Upper-left scattered -->
		<rect class="sq" x="248" y="65" width="78" height="78" rx="6" />
		<rect class="sq" x="328" y="148" width="78" height="78" rx="6" />

		<!-- Lower-left isolated -->
		<rect class="sq" x="415" y="320" width="78" height="78" rx="6" />
		<rect class="sq" x="335" y="422" width="78" height="78" rx="6" />

		<!-- Top-center -->
		<rect class="sq" x="378" y="0" width="78" height="78" rx="6" />
		<rect class="sq" x="458" y="0" width="78" height="78" rx="6" />
		<rect class="sq" x="498" y="80" width="78" height="78" rx="6" />
		<rect class="sq" x="418" y="160" width="78" height="78" rx="6" />

		<!-- Top-right cluster -->
		<rect class="sq" x="1087" y="0" width="78" height="78" rx="6" />
		<rect class="sq" x="1167" y="0" width="78" height="78" rx="6" />
		<rect class="sq" x="1327" y="0" width="78" height="78" rx="6" />
		<rect class="sq" x="1247" y="80" width="78" height="78" rx="6" />
		<rect class="sq" x="1327" y="80" width="78" height="78" rx="6" />
		<rect class="sq" x="1327" y="160" width="78" height="78" rx="6" />

		<!-- Right-mid cluster -->
		<rect class="sq" x="908" y="218" width="78" height="78" rx="6" />
		<rect class="sq" x="988" y="218" width="78" height="78" rx="6" />
		<rect class="sq" x="1148" y="218" width="78" height="78" rx="6" />
		<rect class="sq" x="1228" y="218" width="78" height="78" rx="6" />
		<rect class="sq" x="1068" y="298" width="78" height="78" rx="6" />
		<rect class="sq" x="1148" y="298" width="78" height="78" rx="6" />
		<rect class="sq" x="1308" y="298" width="78" height="78" rx="6" />
		<rect class="sq" x="988" y="378" width="78" height="78" rx="6" />
		<rect class="sq" x="1068" y="378" width="78" height="78" rx="6" />
		<rect class="sq" x="1308" y="378" width="78" height="78" rx="6" />

		<!-- Lone lower-center -->
		<rect class="sq" x="808" y="492" width="78" height="78" rx="6" />
	</svg>
</div>

<style>
	#scattered-squares {
		mask-image: linear-gradient(to bottom, black 0%, black 35%, transparent 80%);
		-webkit-mask-image: linear-gradient(to bottom, black 0%, black 35%, transparent 80%);
	}

	.sq {
		fill: rgba(8, 10, 30, 0.65);
		stroke: rgba(60, 60, 200, 0.45);
		stroke-width: 1.5;
		animation: sqPulse 6s ease-in-out infinite;
	}

	@keyframes sqPulse {
		0%, 100% { opacity: 0.35; }
		50% { opacity: 0.9; }
	}
</style>

<script>
	function initSquares() {
		document.querySelectorAll("#scattered-squares .sq").forEach((el) => {
			(el as HTMLElement).style.animationDelay = `-${(Math.random() * 9).toFixed(2)}s`;
			(el as HTMLElement).style.animationDuration = `${(4 + Math.random() * 6).toFixed(2)}s`;
		});
	}
	initSquares();
	document.addEventListener("astro:after-swap", initSquares, { once: false });
</script>
