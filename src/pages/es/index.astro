---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroNew from "@/img/hero-new.jpg";
import MusicCodex from "@/img/phone-hero.png";
import { DotLottieReact } from "@lottiefiles/dotlottie-react";
import { Button } from "@/components/ui/button";

import OtraExpCarousel from "@/components/OtraExpCarousel";
import Waves from "@/components/Waves.astro";
import ScatteredSquares from "@/components/ScatteredSquares.astro";
import HomeAccordion from "@/components/HomeAccordion";
import { Badge } from "@/components/ui/badge";
import DemucsCard from "@/img/demucs-home-card.png";
import SCPPCard from "@/img/scpp-home-card.png";
import AiBriefer from "@/img/ai-briefer-home-card.png";
import FoodManager from "@/img/food-manager-home-card.png";
import Blueprint from "@/img/simple-blueprint-home-card.png";

const astroLocale = Astro.currentLocale;
---

<Layout title="Jose Concha - Full Stack Developer">
	<main>
		<section
			class="pt-10 pb-0 bg-cover bg-center grid-flares-bg overflow-hidden relative"
		>
			<ScatteredSquares />
			<div class="container mx-auto relative z-10">
				<div
					class="flex flex-col items-center text-center max-w-3xl mx-auto mb-10"
				>
					<h1 class="text-5xl md:text-7xl font-bold mb-6">
						<span>Full Stack</span>
						<br />
						<span>Developer</span>
					</h1>
					<p
						class="text-2xl bg-clip-text text-transparent mb-2"
						style="background-image: linear-gradient(66.77deg, #d83333, #f041ff);"
					>
						Lógica operativa, Diseño y Construcción
					</p>
					<p class="pb-6 text-center">
						Enfoque integral en todas las etapas del desarrollo de
						software, garantizando una ejecución sin interrupciones
						y resultados en cada etapa del proyecto
					</p>
					<a
						href="https://www.linkedin.com/in/jose-miguel-concha/"
						target="_blank"
					>
						<Button className="flex justify-between gap-2">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="icon icon-tabler icon-tabler-brand-linkedin max-w-6"
								width="44"
								height="44"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="#2c3e50"
								fill="none"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									stroke="none"
									d="M0 0h24v24H0z"
									fill="none"></path>
								<path
									d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z"
								></path>
								<path d="M8 11l0 5"></path>
								<path d="M8 8l0 .01"></path>
								<path d="M12 16l0 -5"></path>
								<path d="M16 16v-3a2 2 0 0 0 -4 0"></path>
							</svg>
							LinkedIn
						</Button>
					</a>
				</div>
			</div>
			<div class="relative flex items-end justify-center gap-0">
				<div
					class="absolute inset-0 z-10 pointer-events-none"
					style="background: linear-gradient(to bottom, transparent 80%, hsl(var(--background)) 100%);"
				>
				</div>
				<div class="relative w-3/4 md:w-3/5 shrink-0">
					<div
						class="rounded-xl border border-slate-600/60 shadow-2xl shadow-black/60 overflow-hidden bg-slate-900"
					>
						<div
							class="flex items-center px-3 py-2 bg-[#1a1a2e] relative"
						>
							<div class="flex gap-2">
								<span
									class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-[#ff5f57]"
								></span>
								<span
									class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-[#febc2e]"
								></span>
								<span
									class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-[#28c840]"
								></span>
							</div>
						</div>
						<Image src={HeroNew} alt="" class="w-full block" />
					</div>
				</div>
				<div
					class="relative w-1/5 md:w-1/7 shrink-0 self-end ml-[-12.5%] md:ml-[-5%]"
				>
					<Image src={MusicCodex} alt="" class="w-full" />
				</div>
			</div>
		</section>
		<section class="py-16">
			<div class="container mx-auto relative z-10">
				<h2 class="text-5xl font-bold mb-10">Expertiz</h2>
				<div
					class="flex flex-col lg:grid grid-cols-3 border-2 border-slate-300
				lg:divide-x-2 divide-slate-300"
				>
					<div class="grid p-6">
						<h3 class="font-dotgothic16 text-4xl font-bold mb-4">
							<span class="chonky-underline-orange relative"
								>Lógica</span
							> operativa
						</h3>
						<p>
							Con experiencia en diseño de procesos
							administrativos y KPIs, mi enfoque es mejorar la
							eficiencia operativa, reducir tiempos de entrega y
							maximizar resultados.
						</p>
						<p>
							Experiencia en análisis de datos para informar
							decisiones comerciales y diseñar soluciones
							informáticas efectivas
						</p>
					</div>
					<div class="grid p-6">
						<h3 class="font-dotgothic16 text-4xl font-bold mb-4">
							<span class="chonky-underline-magenta relative"
								>Backend</span
							>
						</h3>
						<p>
							Desarrollo de aplicaciones utilizando Java, Play
							Framework, Javascript, NodeJS, SailsJS, MySQL.
						</p>
						<p>
							Priorizo sistemas robustos con alta calidad y
							rendimiento, actualmente manejando más de 50
							usuarios simultáneos en dispositivos móviles y de
							escritorio.
						</p>
					</div>
					<div class="grid p-6">
						<h3 class="font-dotgothic16 text-4xl font-bold mb-4">
							<span class="relative chonky-underline-blue">
								Frontend
							</span>
						</h3>
						<p>
							He trabajado con Vue.js, React y React Native,
							creando interfaces dinámicas y responsivas, así como
							aplicaciones móviles nativas.
						</p>
						<p>
							Mi objetivo es maximizar estas herramientas para
							ofrecer experiencias de usuario excepcionales y
							funcionales.
						</p>
					</div>
				</div>
			</div>
		</section>
		<section class="py-16">
			<!-- <section class="py-16 relative bg-linear-to-b from-sky-950 from-60% to-transparent"> -->
			<!-- <SvgBlob /> -->
			<div class="container mx-auto">
				<div class="grid grid-cols-3 mb-10">
					<div class="col-span-2">
						<a href="/#proyectos"></a>
						<div
							class="flex gap-2 items-center mb-4 fade-in-fwd"
							style="animation-timeline: view(70% 0%);"
						>
							<img
								src={`${import.meta.env.BASE_URL}img/ruler-icon.png`}
								class="max-h-10"
							/>
							<h2 class="text-5xl font-bold proyectos-h2">
								Proyectos
							</h2>
						</div>
						<p
							class="mb-0 fade-in-fwd"
							style="animation-timeline: view(70% 0%);"
						>
							Todos los proyectos presentados aquí son el
							resultado de mi iniciativa personal y creatividad,
							surgidos para resolver problemas cotidianos sin
							soluciones disponibles en el mercado. Reflejan mi
							pasión por la innovación tecnológica y mi capacidad
							para identificar y aprovechar oportunidades con
							éxito.
						</p>
					</div>
					<div class="flex justify-self-center">
						<DotLottieReact
							src={`${import.meta.env.BASE_URL}img/astronaut.lottie`}
							autoplay
							loop
							client:visible
							className="w-35"
						/>
					</div>
				</div>
				<div class="flex flex-col lg:grid grid-cols-3 gap-6">
					<a
						href={`${import.meta.env.BASE_URL}es/proyectos/demucs`}
						class="rounded-3xl border group transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-neutral-400 dark:hover:border-neutral-500 cursor-pointer block"
					>
						<div class="h-80 overflow-hidden">
							<Image
								src={DemucsCard}
								alt=""
								class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
							/>
						</div>
						<div class="py-4 px-8 flex flex-col gap-4">
							<h3 class="font-dotgothic16 text-3xl font-bold">
								Demucs
							</h3>
							<div>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									AI
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									Python
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									VueJS
								</Badge>
							</div>
							<p>
								Interfaz Web y API que habilita modelo de
								separación para dividir batería, bajo y voces
								del resto del acompañamiento de una canción
							</p>
						</div>
					</a>
					<a
						href={`${import.meta.env.BASE_URL}es/proyectos/scpp`}
						class="rounded-3xl border col-span-2 group transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-neutral-400 dark:hover:border-neutral-500 cursor-pointer block"
					>
						<div class="h-80 overflow-hidden">
							<Image
								src={SCPPCard}
								alt=""
								class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
							/>
						</div>
						<div class="py-4 px-8 flex flex-col gap-4">
							<h3 class="font-dotgothic16 text-3xl font-bold">
								SCPP
							</h3>
							<div>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									Bun
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									MySQL
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									React
								</Badge>
							</div>
							<p>
								Sistema de Control de Presupuesto Personal. Es
								la solución integral para gestionar tus finanzas
								personales de manera eficiente y conveniente.
								Con su aplicación para Android y su versión de
								escritorio para Windows, SCPP te ofrece la
								flexibilidad para registrar tus gastos, ingresos
								y ahorros en cualquier momento y desde cualquier
								lugar.
							</p>
						</div>
					</a>

					<a
						href={`${import.meta.env.BASE_URL}es/proyectos/apps-react-native`}
						class="rounded-3xl border group transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-neutral-400 dark:hover:border-neutral-500 cursor-pointer block"
					>
						<div class="h-80 overflow-hidden">
							<Image
								src={FoodManager}
								alt=""
								class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
							/>
						</div>
						<div class="py-4 px-8 flex flex-col gap-4">
							<h3 class="font-dotgothic16 text-3xl font-bold">
								Food Manager & Music Codex
							</h3>
							<div>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									React Native
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									Supabase
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									Typescript
								</Badge>
							</div>
							<p>
								Dos aplicaciones móviles desarrolladas con React
								Native creadas para dar soluciones prácticas,
								eficientes y orientadas a la experiencia de
								usuario.
							</p>
						</div>
					</a>
					<a
						href={`${import.meta.env.BASE_URL}es/proyectos/simple-blueprint`}
						class="rounded-3xl border group transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-neutral-400 dark:hover:border-neutral-500 cursor-pointer block"
					>
						<div class="h-80 overflow-hidden">
							<Image
								src={Blueprint}
								alt=""
								class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
							/>
						</div>
						<div class="py-4 px-8 flex flex-col gap-4">
							<h3 class="font-dotgothic16 text-3xl font-bold">
								Simple Blueprint
							</h3>
							<div>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									React
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									Shadcn
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									IndexedDB
								</Badge>
							</div>
							<p>
								Un editor de planos rápido y sin complicaciones
								que corre completamente en tu navegador. Sin
								cuenta. Sin suscripción. Sin servidor. Ábrelo y
								empieza a dibujar.
							</p>
						</div>
					</a>
					<a
						href={`${import.meta.env.BASE_URL}es/proyectos/ai-youtube-briefer`}
						class="rounded-3xl border group transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-neutral-400 dark:hover:border-neutral-500 cursor-pointer block"
					>
						<div class="h-80 overflow-hidden">
							<Image
								src={AiBriefer}
								alt=""
								class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
							/>
						</div>
						<div class="py-4 px-8 flex flex-col gap-4">
							<h3 class="font-dotgothic16 text-3xl font-bold">
								AI Youtube Briefer
							</h3>
							<div>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									OpenAI
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									Anthopic
								</Badge>
								<Badge
									className="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300"
								>
									Tauri
								</Badge>
							</div>
							<p>
								Transcribe un video de Youtube y lo procesa con
								IA para obtener un resumen completo del
								contenido con un solo click
							</p>
						</div>
					</a>
				</div>
			</div>
		</section>
	</main>
	<footer class="p-6">
		<div class="container mx-auto">
			<div class="flex flex-col md:grid md:grid-cols-2 gap-16">
				<div>
					<h2
						class="text-5xl font-bold chonky-drop-line font-dotgothic16 mb-4
						relative chonky-underline-magenta w-fit"
					>
						Contactame
					</h2>
					<p>
						¿Tienes un proyecto emocionante en el que necesitas
						ayuda? Contáctame a través de mensaje
					</p>
					<a
						href="https://www.linkedin.com/in/jose-miguel-concha/"
						target="_blank"
					>
						<Button className="flex justify-between gap-2">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="icon icon-tabler icon-tabler-brand-linkedin max-w-6"
								width="44"
								height="44"
								viewBox="0 0 24 24"
								stroke-width="1.5"
								stroke="#2c3e50"
								fill="none"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									stroke="none"
									d="M0 0h24v24H0z"
									fill="none"></path>
								<path
									d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z"
								></path>
								<path d="M8 11l0 5"></path>
								<path d="M8 8l0 .01"></path>
								<path d="M12 16l0 -5"></path>
								<path d="M16 16v-3a2 2 0 0 0 -4 0"></path>
							</svg>
							LinkedIn
						</Button>
					</a>
					<div class="mt-8">
						<HomeAccordion client:visible locale={astroLocale} />
					</div>
				</div>
				<div>
					<h2 class="text-5xl font-bold mb-4">
						Experiencia Adicional
					</h2>
					<OtraExpCarousel client:idle locale={astroLocale} />
				</div>
			</div>
		</div>
	</footer>
	<br />
	<Waves wavesOpacity={[0.5, 0.7, 0.3]} />
</Layout>
