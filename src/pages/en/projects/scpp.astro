---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import ReactIcon from "@/img/react-icon.png";
import NodeIcon from "@/img/node-icon.png";
import AndroidIcon from "@/img/android-icon.png";
import ScppHero from "@/img/scpp-hero.png";
import Scpp2 from "@/img/scpp-show-new.png";
import CrazyLine from "@/components/CrazyLine.astro";
import ScatteredSquares from "@/components/ScatteredSquares.astro";
---

<Layout title="Personal Budget System">
    <section
        class="pt-10 pb-0 bg-cover bg-center overflow-hidden relative"
    >
        <ScatteredSquares />
        <div class="container mx-auto z-10 relative">
            <div class="grid md:grid-cols-5 items-center justify-center gap-20">
                <div class="md:col-span-3">
                    <h1 class="text-7xl font-bold mb-10 font-dotgothic16">
                        SCPP
                    </h1>
                    <p>
                        Available for Android and Windows, SCPP is a
                        financial management tool that centralizes the
                        control of expenses, income, and savings from any
                        device.
                    </p>
                </div>
                <div class="video-wrapper mx-auto md:col-span-2">
                    <div class="video-flare"></div>
                <div class="video-showcase">
                    <div class="video-titlebar">
                        <div class="flex gap-1.5 items-center shrink-0">
                            <span class="w-3 h-3 rounded-full bg-red-500/80"
                            ></span>
                            <span class="w-3 h-3 rounded-full bg-yellow-400/80"
                            ></span>
                            <span class="w-3 h-3 rounded-full bg-green-500/80"
                            ></span>
                        </div>
                        <span
                            class="text-xs text-slate-400 absolute left-1/2 -translate-x-1/2 tracking-wide"
                            >SCPP — Budget Control</span
                        >
                    </div>
                    <video
                        src={`${import.meta.env.BASE_URL}video/scpp.mp4`}
                        autoplay
                        muted
                        loop
                        playsinline
                        class="w-full block"></video>
                </div>
                </div>
            </div>
        </div>

        <div class="container mx-auto flex flex-col gap-24 mt-20 relative">
            <!-- ── The Problem ──────────────────────────────────── -->
            <div class="grid md:grid-cols-5 gap-10 lg:gap-20 items-center">
                <!-- Hero image -->
                <Image
                    src={ScppHero}
                    alt="SCPP App Preview"
                    class="w-full md:col-span-2"
                />

                <!-- Pain points -->
                <div class="flex flex-col gap-6 md:col-span-3">
                    <div>
                        <span
                            class="text-xs font-mono text-cyan-400/80 tracking-widest uppercase"
                            >The Problem</span
                        >
                        <h2 class="text-2xl font-bold mt-1">
                            Why build it?
                        </h2>
                    </div>

                    <p class="text-sm text-slate-400 leading-relaxed">
                        SCPP was born from the need for a simple solution
                        to track expenses and income efficiently. A direct,
                        frictionless tool to keep financial records up to date.
                    </p>

                    <div class="flex flex-col gap-2">
                        <div
                            class="flex items-start gap-3 p-4 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 transition-colors group"
                        >
                            <div
                                class="w-7 h-7 rounded-full bg-red-950/60 border border-red-900/50 flex items-center justify-center shrink-0 mt-0.5"
                            >
                                <svg
                                    width="11"
                                    height="11"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-red-400"
                                    ><path d="M18 6L6 18M6 6l12 12"></path></svg
                                >
                            </div>
                            <div>
                                <p
                                    class="text-sm font-medium text-slate-200 group-hover:text-white transition-colors"
                                >
                                    Expensive subscriptions
                                </p>
                                <p
                                    class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                >
                                    Existing apps charge monthly for
                                    basic tracking features.
                                </p>
                            </div>
                        </div>

                        <div
                            class="flex items-start gap-3 p-4 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 transition-colors group"
                        >
                            <div
                                class="w-7 h-7 rounded-full bg-red-950/60 border border-red-900/50 flex items-center justify-center shrink-0 mt-0.5"
                            >
                                <svg
                                    width="11"
                                    height="11"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-red-400"
                                    ><path d="M18 6L6 18M6 6l12 12"></path></svg
                                >
                            </div>
                            <div>
                                <p
                                    class="text-sm font-medium text-slate-200 group-hover:text-white transition-colors"
                                >
                                    Complex interfaces
                                </p>
                                <p
                                    class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                >
                                    Too many unnecessary features that
                                    complicate daily logging.
                                </p>
                            </div>
                        </div>

                        <div
                            class="flex items-start gap-3 p-4 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 transition-colors group"
                        >
                            <div
                                class="w-7 h-7 rounded-full bg-red-950/60 border border-red-900/50 flex items-center justify-center shrink-0 mt-0.5"
                            >
                                <svg
                                    width="11"
                                    height="11"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-red-400"
                                    ><path d="M18 6L6 18M6 6l12 12"></path></svg
                                >
                            </div>
                            <div>
                                <p
                                    class="text-sm font-medium text-slate-200 group-hover:text-white transition-colors"
                                >
                                    No customization
                                </p>
                                <p
                                    class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                >
                                    No tool matched the specific
                                    requirements I was looking for.
                                </p>
                            </div>
                        </div>
                    </div>

                    <p class="text-sm text-slate-400 leading-relaxed">
                        So I built a custom solution that fit
                        exactly what was needed.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 relative">
        <CrazyLine static />
        <div class="container mx-auto flex flex-col gap-20">
            <!-- ── The Architecture ──────────────────────────────── -->
            <div class="flex flex-col gap-10">
                <div class="text-center">
                    <span
                        class="text-xs font-mono text-cyan-400/80 tracking-widest uppercase"
                        >The Architecture</span
                    >
                    <h2 class="text-2xl font-bold mt-1">How SCPP works</h2>
                    <p
                        class="text-sm text-slate-400 mt-3 max-w-lg mx-auto leading-relaxed"
                    >
                        A shared Node.js backend acts as a
                        microservice for both clients, centralizing
                        access to the MySQL database.
                    </p>
                </div>

                <!-- Architecture flow diagram -->
                <div
                    class="relative rounded-xl border border-slate-800 bg-slate-950/80 p-6 md:p-8 overflow-hidden"
                >
                    <div
                        class="absolute inset-0 opacity-20 rounded-xl"
                        style="background-image: radial-gradient(circle, rgba(148,163,184,0.25) 1px, transparent 1px); background-size: 28px 28px;"
                    >
                    </div>

                    <div
                        class="relative flex flex-col md:flex-row md:items-stretch gap-4 md:gap-0"
                    >
                        <!-- Client tier -->
                        <div class="flex flex-col gap-1 md:flex-1">
                            <p
                                class="text-[10px] font-mono text-slate-600 tracking-widest uppercase mb-3"
                            >
                                Clients
                            </p>
                            <div class="flex flex-col gap-3 flex-1">
                                <div
                                    class="rounded-lg border border-slate-800 bg-slate-900 p-4 flex items-start gap-3 hover:border-slate-700 transition-colors"
                                >
                                    <div
                                        class="w-8 h-8 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0"
                                    >
                                        <Image
                                            src={AndroidIcon}
                                            alt="Android"
                                            class="w-5 h-5 object-contain"
                                        />
                                    </div>
                                    <div class="min-w-0">
                                        <p
                                            class="text-sm font-semibold text-slate-200"
                                        >
                                            Android App
                                        </p>
                                        <p
                                            class="text-[11px] text-slate-500 mt-0.5"
                                        >
                                            React Native
                                        </p>
                                        <div class="flex gap-1 mt-2 flex-wrap">
                                            <span
                                                class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                                >Expenses</span
                                            >
                                            <span
                                                class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                                >Charts</span
                                            >
                                            <span
                                                class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                                >Search</span
                                            >
                                        </div>
                                    </div>
                                </div>

                                <div
                                    class="rounded-lg border border-slate-800 bg-slate-900 p-4 flex items-start gap-3 hover:border-slate-700 transition-colors"
                                >
                                    <div
                                        class="w-8 h-8 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0"
                                    >
                                        <Image
                                            src={ReactIcon}
                                            alt="React"
                                            class="w-5 h-5 object-contain"
                                        />
                                    </div>
                                    <div class="min-w-0">
                                        <p
                                            class="text-sm font-semibold text-slate-200"
                                        >
                                            Web Client
                                        </p>
                                        <p
                                            class="text-[11px] text-slate-500 mt-0.5"
                                        >
                                            React + shadcn/ui
                                        </p>
                                        <div class="flex gap-1 mt-2 flex-wrap">
                                            <span
                                                class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                                >No install</span
                                            >
                                            <span
                                                class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                                >Auto-updates</span
                                            >
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Arrow connector 1 -->
                        <div
                            class="flex items-center justify-center py-2 md:py-0 md:self-stretch md:flex-col md:gap-2 md:px-4"
                        >
                            <div
                                class="hidden md:block flex-1 w-px bg-linear-to-b from-transparent via-slate-700/60 to-transparent"
                            >
                            </div>
                            <div
                                class="w-6 h-6 rounded-full border border-slate-700 bg-slate-950 flex items-center justify-center shrink-0"
                            >
                                <svg
                                    width="10"
                                    height="10"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-slate-500 rotate-90 md:rotate-0"
                                    ><polyline points="9 18 15 12 9 6"
                                    ></polyline></svg
                                >
                            </div>
                            <div
                                class="hidden md:block flex-1 w-px bg-linear-to-b from-transparent via-slate-700/60 to-transparent"
                            >
                            </div>
                        </div>

                        <!-- API tier -->
                        <div class="flex flex-col gap-1 md:flex-1">
                            <p
                                class="text-[10px] font-mono text-slate-600 tracking-widest uppercase mb-3"
                            >
                                Backend
                            </p>
                            <div
                                class="rounded-lg border border-cyan-900/50 bg-slate-900 p-4 flex items-start gap-3 flex-1 shadow-[0_0_25px_rgba(6,182,212,0.07)] hover:border-cyan-800/60 transition-colors"
                            >
                                <div
                                    class="w-8 h-8 rounded-lg bg-cyan-950/40 border border-cyan-900/50 flex items-center justify-center shrink-0"
                                >
                                    <Image
                                        src={NodeIcon}
                                        alt="Node.js"
                                        class="w-5 h-5 object-contain"
                                    />
                                </div>
                                <div class="min-w-0">
                                    <p
                                        class="text-sm font-semibold text-slate-200"
                                    >
                                        REST API
                                    </p>
                                    <p
                                        class="text-[11px] text-slate-500 mt-0.5"
                                    >
                                        Node.js · Microservice
                                    </p>
                                    <div class="flex gap-1 mt-2 flex-wrap">
                                        <span
                                            class="text-[10px] px-1.5 py-0.5 rounded bg-cyan-950/40 border border-cyan-900/40 text-cyan-400"
                                            >Shared</span
                                        >
                                        <span
                                            class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                            >MySQL driver</span
                                        >
                                    </div>
                                    <p
                                        class="text-xs text-slate-500 mt-3 leading-relaxed"
                                    >
                                        Centralizes data access for both
                                        platforms, simplifying
                                        maintenance.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Arrow connector 2 -->
                        <div
                            class="flex items-center justify-center py-2 md:py-0 md:self-stretch md:flex-col md:gap-2 md:px-4"
                        >
                            <div
                                class="hidden md:block flex-1 w-px bg-linear-to-b from-transparent via-slate-700/60 to-transparent"
                            >
                            </div>
                            <div
                                class="w-6 h-6 rounded-full border border-slate-700 bg-slate-950 flex items-center justify-center shrink-0"
                            >
                                <svg
                                    width="10"
                                    height="10"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-slate-500 rotate-90 md:rotate-0"
                                    ><polyline points="9 18 15 12 9 6"
                                    ></polyline></svg
                                >
                            </div>
                            <div
                                class="hidden md:block flex-1 w-px bg-linear-to-b from-transparent via-slate-700/60 to-transparent"
                            >
                            </div>
                        </div>

                        <!-- DB tier -->
                        <div class="flex flex-col gap-1 md:flex-1">
                            <p
                                class="text-[10px] font-mono text-slate-600 tracking-widest uppercase mb-3"
                            >
                                Database
                            </p>
                            <div
                                class="rounded-lg border border-slate-800 bg-slate-900 p-4 flex items-start gap-3 hover:border-slate-700 transition-colors"
                            >
                                <div
                                    class="w-8 h-8 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-slate-400"
                                    >
                                        <ellipse cx="12" cy="5" rx="9" ry="3"
                                        ></ellipse>
                                        <path
                                            d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"
                                        ></path>
                                        <path
                                            d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"
                                        ></path>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p
                                        class="text-sm font-semibold text-slate-200"
                                    >
                                        MySQL
                                    </p>
                                    <p
                                        class="text-[11px] text-slate-500 mt-0.5"
                                    >
                                        Relational Database
                                    </p>
                                    <div class="flex gap-1 mt-2 flex-wrap">
                                        <span
                                            class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                            >Assets</span
                                        >
                                        <span
                                            class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                            >Categories</span
                                        >
                                        <span
                                            class="text-[10px] px-1.5 py-0.5 rounded bg-slate-800 text-slate-400"
                                            >Documents</span
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pb-20">
        <div class="container mx-auto">
            <div class="grid md:grid-cols-5 gap-10 lg:gap-20 items-center">
                <Image src={Scpp2} alt="SCPP new version" class="w-full md:col-span-2" />

                <div class="flex flex-col gap-12 md:col-span-3">
                    <div>
                        <span
                            class="text-xs font-mono text-cyan-400/80 tracking-widest uppercase"
                            >The Evolution</span
                        >
                        <h2 class="text-2xl font-bold mt-1">What changed</h2>
                    </div>

                    <p class="text-sm text-slate-400 leading-relaxed -mt-6">
                        Continuous use surfaced new needs that the
                        initial design didn't account for. What started as
                        minor adjustments became a much more complete
                        second iteration.
                    </p>

                    <!-- Numbered narrative — no boxes, pure type + subtle thread -->
                    <div class="relative flex flex-col gap-10 pl-5">
                        <div
                            class="absolute left-0 top-1 bottom-1 w-px bg-linear-to-b from-cyan-500/50 via-slate-700/40 to-transparent"
                        ></div>

                        <div class="flex flex-col gap-1.5">
                            <span
                                class="text-[11px] font-mono text-cyan-400/60 tracking-widest"
                                >01</span
                            >
                            <h3 class="text-lg font-semibold text-white">
                                Full rewrite
                            </h3>
                            <p class="text-sm text-slate-400 leading-relaxed">
                                Migrated to the latest version of React Native
                                with a redesigned layout informed by
                                accumulated experience.
                            </p>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <span
                                class="text-[11px] font-mono text-cyan-400/60 tracking-widest"
                                >02</span
                            >
                            <h3 class="text-lg font-semibold text-white">
                                Better performance
                            </h3>
                            <p class="text-sm text-slate-400 leading-relaxed">
                                Faster and more efficient app, with a better
                                development experience and smoother performance
                                across all areas.
                            </p>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <span
                                class="text-[11px] font-mono text-cyan-400/60 tracking-widest"
                                >03</span
                            >
                            <h3 class="text-lg font-semibold text-white">
                                Document management
                            </h3>
                            <p class="text-sm text-slate-400 leading-relaxed">
                                New section to attach photos with date and
                                description, centralizing the tracking of
                                important records.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .video-wrapper {
        position: relative;
    }
    .video-flare {
        position: absolute;
        inset: -60px;
        background: radial-gradient(ellipse at center, rgba(167, 80, 255, 0.85) 0%, rgba(139, 40, 255, 0.65) 30%, rgba(109, 20, 200, 0.4) 55%, rgba(88, 28, 180, 0.15) 72%, transparent 85%);
        filter: blur(48px);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }
    .video-showcase {
        position: relative;
        z-index: 1;
        border: 1px solid rgba(109, 232, 255, 0.2);
        border-radius: 8px;
        overflow: hidden;
        box-shadow:
            0 0 0 1px rgba(109, 232, 255, 0.05),
            0 0 40px rgba(109, 232, 255, 0.08),
            0 8px 32px rgba(0, 0, 0, 0.5);
        background: #0f172a;
    }
    .video-titlebar {
        background: rgba(15, 23, 42, 0.95);
        border-bottom: 1px solid rgba(109, 232, 255, 0.12);
        padding: 8px 12px;
        display: flex;
        align-items: center;
        position: relative;
        gap: 8px;
    }
</style>
