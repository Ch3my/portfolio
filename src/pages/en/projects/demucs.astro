---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import Demucs2 from "@/img/demucs-new-2.png";
import PythonIcon from "@/img/python-icon.png";
import VueIcon from "@/img/vue-icon-2.png";
import ScatteredSquares from "@/components/ScatteredSquares.astro";
import DemucsHeroPlayer from "@/components/DemucsHeroPlayer.astro";
import { Lock, Music, Gauge } from "lucide-react";
import CrazyLine from "@/components/CrazyLine.astro";
---

<Layout title="Music Source Separation">
    <section
        class="py-10 bg-cover bg-center grid-flares-bg overflow-hidden relative"
    >
        <ScatteredSquares />
        <div class="container mx-auto relative z-10">
            <div class="grid md:grid-cols-3">
                <div class="md:col-span-2">
                    <h1 class="text-7xl font-bold mb-10 font-dotgothic16">
                        Demucs
                    </h1>
                    <p>
                        Web interface and API that enables a separation model
                        to split drums, bass, and vocals from the rest of a
                        song's accompaniment. Listen to some examples in
                        the player.
                    </p>
                </div>
                <div class="mx-auto">
                    <DemucsHeroPlayer />
                </div>
            </div>
        </div>
    </section>
    <section class="py-28 relative overflow-hidden">
        <div
            class="absolute top-0 inset-x-0 h-px bg-linear-to-r from-transparent via-slate-700/50 to-transparent"
        >
        </div>
        <div class="container mx-auto relative">
            <div class="text-center mb-20 max-w-2xl mx-auto">
                <span
                    class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-slate-500 mb-6"
                >
                    The Problem
                </span>
                <h2
                    class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] mb-6 text-slate-100"
                >
                    Making music shouldn't<br />
                    <span class="text-slate-400 font-light"
                        >come with a price of entry</span
                    >
                </h2>
                <p class="text-slate-400 text-base md:text-lg leading-relaxed">
                    Separating vocals and instruments from a recording is a
                    real need for musicians and hobbyists. Existing solutions
                    hide this capability behind subscriptions that not
                    everyone can afford.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-4">
                <div
                    class="group relative rounded-2xl border border-slate-800 bg-slate-900/60 p-8 hover:border-slate-700 hover:bg-slate-900/90 transition-all duration-300"
                >
                    <div
                        class="w-10 h-10 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center mb-8 group-hover:border-slate-600 transition-colors duration-300"
                    >
                        <Lock className="w-4 h-4 text-slate-300" />
                    </div>
                    <h3
                        class="text-sm font-semibold tracking-tight text-slate-200 mb-3"
                    >
                        Locked Behind a Subscription
                    </h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Platforms like Moises and Lalal.ai limit separation
                        quality to monthly plans, putting the best tools out
                        of reach for the casual musician.
                    </p>
                </div>

                <div
                    class="group relative rounded-2xl border border-slate-800 bg-slate-900/60 p-8 hover:border-slate-700 hover:bg-slate-900/90 transition-all duration-300"
                >
                    <div
                        class="w-10 h-10 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center mb-8 group-hover:border-slate-600 transition-colors duration-300"
                    >
                        <Music className="w-4 h-4 text-slate-300" />
                    </div>
                    <h3
                        class="text-sm font-semibold tracking-tight text-slate-200 mb-3"
                    >
                        Not Built for Hobbyists
                    </h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Advanced tools are geared toward studios and producers.
                        Those who play music as a hobby are excluded from the
                        most useful features.
                    </p>
                </div>

                <div
                    class="group relative rounded-2xl border border-slate-800 bg-slate-900/60 p-8 hover:border-slate-700 hover:bg-slate-900/90 transition-all duration-300"
                >
                    <div
                        class="w-10 h-10 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center mb-8 group-hover:border-slate-600 transition-colors duration-300"
                    >
                        <Gauge className="w-4 h-4 text-slate-300" />
                    </div>
                    <h3
                        class="text-sm font-semibold tracking-tight text-slate-200 mb-3"
                    >
                        Artificial Usage Limits
                    </h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Free services cut you off at a few songs per month,
                        right when you need them most and at the worst time
                        to pay.
                    </p>
                </div>
            </div>
        </div>
        <CrazyLine static />
        <div
            class="absolute bottom-0 inset-x-0 h-px bg-linear-to-r from-transparent via-slate-700/50 to-transparent"
        >
        </div>
    </section>
    <section class="py-24 relative overflow-hidden">
        <div class="container mx-auto">
            <div class="grid md:grid-cols-2 gap-10 items-center">
                <div class="relative overflow-hidden rounded-2xl">
                    <Image
                        src={Demucs2}
                        alt="Musician playing guitar"
                        class="w-full h-full object-cover"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-slate-950/50 to-transparent"
                    >
                    </div>
                </div>

                <div>
                    <span
                        class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-slate-500 mb-6"
                    >
                        The Architecture
                    </span>
                    <h2
                        class="text-3xl md:text-4xl font-bold tracking-tight leading-tight mb-8 text-slate-100"
                    >
                        A simple design,<br />
                        <span class="text-slate-400 font-light"
                            >built to work.</span
                        >
                    </h2>

                    <div class="space-y-3 mb-10">
                        <div
                            class="flex gap-4 items-start p-5 rounded-xl border border-slate-800 bg-slate-900/40"
                        >
                            <div
                                class="w-9 h-9 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0"
                            >
                                <Image
                                    src={PythonIcon}
                                    alt="Python"
                                    class="w-5 h-5 object-contain"
                                />
                            </div>
                            <div>
                                <p
                                    class="text-xs font-semibold tracking-[0.2em] uppercase text-slate-500 mb-1"
                                >
                                    Backend
                                </p>
                                <p
                                    class="text-slate-300 text-sm leading-relaxed"
                                >
                                    Python application that exposes a REST API
                                    to interact with the Demucs model,
                                    coordinating the entire track separation
                                    process.
                                </p>
                            </div>
                        </div>

                        <div
                            class="flex gap-4 items-start p-5 rounded-xl border border-slate-800 bg-slate-900/40"
                        >
                            <div
                                class="w-9 h-9 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0"
                            >
                                <Image
                                    src={VueIcon}
                                    alt="Vue.js"
                                    class="w-5 h-5 object-contain"
                                />
                            </div>
                            <div>
                                <p
                                    class="text-xs font-semibold tracking-[0.2em] uppercase text-slate-500 mb-1"
                                >
                                    Frontend
                                </p>
                                <p
                                    class="text-slate-300 text-sm leading-relaxed"
                                >
                                    Vue.js interface for uploading songs,
                                    launching the separation, and downloading
                                    each resulting track intuitively.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div>
                        <p
                            class="text-xs font-semibold tracking-[0.2em] uppercase text-slate-600 mb-3"
                        >
                            Deployment
                        </p>
                        <div class="flex gap-2 flex-wrap">
                            <span
                                class="inline-flex items-center px-3 py-1.5 rounded-full bg-slate-800/80 border border-slate-700 text-slate-300 text-xs font-medium"
                            >
                                Docker
                            </span>
                            <span
                                class="inline-flex items-center px-3 py-1.5 rounded-full bg-slate-800/80 border border-slate-700 text-slate-300 text-xs font-medium"
                            >
                                Google Colab
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
