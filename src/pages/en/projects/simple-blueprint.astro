---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/img/simple-blueprint-1.png";
import Blueprint from "@/img/simple-blueprint-2.png";
import TS from "@/img/ts-icon.png";
import ReactIcon from "@/img/react-icon.png";
import VueIcon from "@/img/vue-icon.png";
import { Image } from "astro:assets";
import Waves from "@/components/Waves.astro";
import CrazyLine from "@/components/CrazyLine.astro";
---

<Layout title="Simple Blueprint">
    <section class="relative overflow-hidden grid-lines-bg hero-glow pb-10">
        <div class="pointer-events-none absolute inset-0 z-0">
            <div
                class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 w-125 h-125 bg-purple-600/30 rounded-full blur-[120px]"
            >
            </div>
            <div
                class="absolute bottom-10 right-8 lg:right-1/4 w-48 h-48 bg-blue-500/20 rounded-full blur-[60px]"
            >
            </div>
        </div>
        <div
            class="relative z-10 pt-16 pb-14 container mx-auto grid md:grid-cols-3 items-center"
        >
            <div class="md:col-span-2 grid gap-4">
                <span class="text-gray-500 font-medium">Blueprint Editor</span>
                <h1 class="text-4xl md:text-5xl font-bold">Simple Blueprint</h1>
                <p class="text-slate-300 prose max-w-prose">
                    A fast, no-fuss blueprint editor that runs entirely in your
                    browser. No account. No subscription. No server. Open it and
                    start drawing.
                </p>
                <div>
                    <a
                        href="https://blueprint.lezora.cl"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-slate-300 border border-slate-700 hover:bg-slate-700 hover:text-white transition-colors"
                    >
                        Try it online
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path
                                d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                            ></path>
                            <polyline points="15 3 21 3 21 9"></polyline>
                            <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                    </a>
                </div>
            </div>
            <Image src={Hero} alt="" class="w-full" />
        </div>
    </section>
    <section class="pb-16 relative z-10 -mt-16">
        <div class="container mx-auto">
            <div
                class="grid grid-cols-1 md:grid-cols-2 rounded-xl border border-slate-800 overflow-hidden bg-slate-950 md:w-9/10 mx-auto"
            >
                <!-- Open issues / The Problem -->
                <div class="border-r border-slate-800">
                    <div
                        class="flex items-center gap-2 px-5 py-3 bg-slate-900/80 border-b border-slate-800"
                    >
                        <svg
                            class="text-rose-400 shrink-0"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <circle cx="12" cy="12" r="1" fill="currentColor"
                            ></circle>
                        </svg>
                        <span class="text-sm font-semibold text-slate-200"
                            >3 Open</span
                        >
                        <span class="text-xs text-slate-500 ml-1"
                            >· The Problem</span
                        >
                        <span
                            class="ml-auto inline-flex items-center gap-1 text-xs text-rose-400 bg-rose-950/40 border border-rose-900/50 px-2 py-0.5 rounded-full"
                        >
                            <span class="w-1.5 h-1.5 rounded-full bg-rose-400"
                            ></span>
                            bug
                        </span>
                    </div>

                    <div
                        class="group flex items-start gap-3 px-5 py-4 border-b border-slate-800/60 hover:bg-slate-900/40 transition-colors cursor-default"
                    >
                        <svg
                            class="mt-0.5 shrink-0 text-rose-400"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <circle cx="12" cy="12" r="1" fill="currentColor"
                            ></circle>
                        </svg>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span
                                    class="text-sm font-medium text-slate-200 group-hover:text-white transition-colors"
                                    >Mandatory sign-up</span
                                >
                                <span
                                    class="text-[10px] px-1.5 py-0.5 rounded-full border border-rose-900/60 text-rose-400 bg-rose-950/30"
                                    >blocker</span
                                >
                            </div>
                            <p
                                class="text-xs text-slate-500 mt-1 mb-1 leading-relaxed"
                            >
                                Account, subscription, or login required before
                                you can draw a single line.
                            </p>
                            <span class="text-[10px] text-slate-600"
                                >#001 · opened by other-tools</span
                            >
                        </div>
                    </div>

                    <div
                        class="group flex items-start gap-3 px-5 py-4 border-b border-slate-800/60 hover:bg-slate-900/40 transition-colors cursor-default"
                    >
                        <svg
                            class="mt-0.5 shrink-0 text-rose-400"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <circle cx="12" cy="12" r="1" fill="currentColor"
                            ></circle>
                        </svg>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span
                                    class="text-sm font-medium text-slate-200 group-hover:text-white transition-colors"
                                    >Doesn't work offline</span
                                >
                                <span
                                    class="text-[10px] px-1.5 py-0.5 rounded-full border border-rose-900/60 text-rose-400 bg-rose-950/30"
                                    >bug</span
                                >
                            </div>
                            <p
                                class="text-xs text-slate-500 mt-1 mb-1 leading-relaxed"
                            >
                                Without a connection you can't access your own
                                work.
                            </p>
                            <span class="text-[10px] text-slate-600"
                                >#002 · opened by other-tools</span
                            >
                        </div>
                    </div>

                    <div
                        class="group flex items-start gap-3 px-5 py-4 hover:bg-slate-900/40 transition-colors cursor-default"
                    >
                        <svg
                            class="mt-0.5 shrink-0 text-rose-400"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <circle cx="12" cy="12" r="1" fill="currentColor"
                            ></circle>
                        </svg>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span
                                    class="text-sm font-medium text-slate-200 group-hover:text-white transition-colors"
                                    >Inaccurate dimensions</span
                                >
                                <span
                                    class="text-[10px] px-1.5 py-0.5 rounded-full border border-amber-900/60 text-amber-400 bg-amber-950/30"
                                    >ux</span
                                >
                            </div>
                            <p
                                class="text-xs text-slate-500 mt-1 mb-1 leading-relaxed"
                            >
                                Visual aesthetics override real physical
                                measurements.
                            </p>
                            <span class="text-[10px] text-slate-600"
                                >#003 · opened by other-tools</span
                            >
                        </div>
                    </div>
                </div>

                <!-- Closed / The Solution -->
                <div>
                    <div
                        class="flex items-center gap-2 px-5 py-3 bg-slate-900/80 border-b border-slate-800"
                    >
                        <svg
                            class="text-purple-400 shrink-0"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="m9 12 2 2 4-4"></path>
                        </svg>
                        <span class="text-sm font-semibold text-slate-200"
                            >3 Closed</span
                        >
                        <span class="text-xs text-slate-500 ml-1"
                            >· The Solution</span
                        >
                        <span
                            class="ml-auto inline-flex items-center gap-1 text-xs text-purple-400 bg-purple-950/40 border border-purple-900/50 px-2 py-0.5 rounded-full"
                        >
                            <span class="w-1.5 h-1.5 rounded-full bg-purple-400"
                            ></span>
                            merged
                        </span>
                    </div>

                    <div
                        class="group flex items-start gap-3 px-5 py-4 border-b border-slate-800/60 hover:bg-slate-900/40 transition-colors cursor-default"
                    >
                        <svg
                            class="mt-0.5 shrink-0 text-purple-400"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="m9 12 2 2 4-4"></path>
                        </svg>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span
                                    class="text-sm font-medium text-slate-400 group-hover:text-slate-300 transition-colors"
                                    >Mandatory sign-up</span
                                >
                                <span
                                    class="text-[10px] px-1.5 py-0.5 rounded-full border border-purple-900/60 text-purple-400 bg-purple-950/30"
                                    >fix: local-first</span
                                >
                            </div>
                            <p
                                class="text-xs text-slate-500 mt-1 mb-1 leading-relaxed"
                            >
                                Everything runs in the browser. No account, no
                                server, no friction.
                            </p>
                            <span class="text-[10px] text-slate-600"
                                >#001 · closed by Jose Concha</span
                            >
                        </div>
                    </div>

                    <div
                        class="group flex items-start gap-3 px-5 py-4 border-b border-slate-800/60 hover:bg-slate-900/40 transition-colors cursor-default"
                    >
                        <svg
                            class="mt-0.5 shrink-0 text-purple-400"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="m9 12 2 2 4-4"></path>
                        </svg>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span
                                    class="text-sm font-medium text-slate-400 group-hover:text-slate-300 transition-colors"
                                    >Doesn't work offline</span
                                >
                                <span
                                    class="text-[10px] px-1.5 py-0.5 rounded-full border border-purple-900/60 text-purple-400 bg-purple-950/30"
                                    >fix: offline</span
                                >
                            </div>
                            <p
                                class="text-xs text-slate-500 mt-1 mb-1 leading-relaxed"
                            >
                                Auto-saves to localStorage. Works offline,
                                always available.
                            </p>
                            <span class="text-[10px] text-slate-600"
                                >#002 · closed by Jose Concha</span
                            >
                        </div>
                    </div>

                    <div
                        class="group flex items-start gap-3 px-5 py-4 hover:bg-slate-900/40 transition-colors cursor-default"
                    >
                        <svg
                            class="mt-0.5 shrink-0 text-purple-400"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="m9 12 2 2 4-4"></path>
                        </svg>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span
                                    class="text-sm font-medium text-slate-400 group-hover:text-slate-300 transition-colors"
                                    >Inaccurate dimensions</span
                                >
                                <span
                                    class="text-[10px] px-1.5 py-0.5 rounded-full border border-purple-900/60 text-purple-400 bg-purple-950/30"
                                    >feat: real-time</span
                                >
                            </div>
                            <p
                                class="text-xs text-slate-500 mt-1 mb-1 leading-relaxed"
                            >
                                Each shape has a physical size in m/cm. Labels
                                update as you draw.
                            </p>
                            <span class="text-[10px] text-slate-600"
                                >#003 · closed by Jose Concha</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <CrazyLine static />
    </section>
    <section class="pb-10">
        <div class="container mx-auto">
            <div class="grid md:grid-cols-3 gap-8 items-center">
                <Image src={Blueprint} alt="" class="w-full" />
                <div class="flex flex-col gap-4 md:col-span-2">
                    <h2 class="text-xl font-bold mb-4">The Architecture</h2>
                    <p>
                        Web application built with React, TypeScript, and Vite.
                        It uses Zustand for state management and stores all
                        projects locally via localStorage, eliminating the need
                        for a backend.
                    </p>
                    <p>
                        Blueprint exports are handled directly in the browser as
                        high-resolution PNG files.
                    </p>
                    <div class="grid grid-cols-5 md:grid-cols-10">
                        <Image src={TS} alt="" class="w-full" />
                        <Image src={ReactIcon} alt="" class="w-full" />
                        <Image src={VueIcon} alt="" class="w-full" />
                    </div>
                </div>
            </div>
        </div>
    </section>
    <Waves wavesOpacity={[0.5, 0.7, 0.9]} />
</Layout>
