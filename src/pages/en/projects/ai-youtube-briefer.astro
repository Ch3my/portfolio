---
import CrazyLine from "@/components/CrazyLine.astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import Img1 from "@/img/conversational_retrieval_chain-5c7a96abe29e582bc575a0a0d63f86b0.png";
import HybridSearchDiagram from "@/components/HybridSearchDiagram";
import Img3 from "@/img/langchain-logo.png";
import Hero from "@/img/ai-briefer-hero.png";
import Waves from "@/components/Waves.astro";
import { Button } from "@/components/ui/button";
import ScatteredSquares from "@/components/ScatteredSquares.astro";
import ConversationalRetrievalChain from "@/components/ConversationalRetrievalChain";
---

<Layout title="AI Youtube Briefer">
    <section
        class="py-10 bg-cover bg-center grid-flares-bg overflow-hidden relative"
    >
        <ScatteredSquares />
        <div class="container mx-auto relative z-10">
            <div class="grid md:grid-cols-2">
                <div>
                    <h1 class="text-7xl font-bold mb-10 font-dotgothic16">
                        AI Youtube Briefer
                    </h1>
                    <p>
                        Transcribes a YouTube video and processes it with AI to
                        get a complete summary of the content with a single
                        click
                    </p>
                </div>
                <Image
                    src={Hero}
                    alt="Main Window Example"
                    class="max-h-96 w-auto slide-in-right relative self-center mx-auto block"
                />
            </div>
            <div class="flex flex-col md:grid grid-cols-3 gap-10 py-8">
                <div>
                    <h2 class="text-2xl font-bold mb-4">
                        1.- Gets the <span
                            class="relative chonky-underline-orange"
                            >transcript</span
                        >
                    </h2>
                    <p>
                        Gets the transcript of a YouTube video and by breaking
                        it into smaller sections, analyzes each section and
                        takes notes.
                    </p>
                </div>
                <div>
                    <h2 class="text-2xl font-bold mb-4">
                        2.- Creates a <span class="relative chonky-underline-magenta"
                            >RAG</span
                        >
                    </h2>
                    <p>
                        Generates a RAG from the text, allowing the user to ask
                        questions about the video and the AI responds using the
                        context
                    </p>
                </div>
                <div>
                    <h2 class="text-2xl font-bold mb-4">
                        3.- Summary and <span
                            class="relative chonky-underline-blue"
                            >questions</span
                        >
                    </h2>
                    <p>
                        Condenses all the notes and organizes them into a single
                        document in an interface that lets you interact with the
                        text
                    </p>
                </div>
            </div>
        </div>
    </section>
    <section class="py-6">
        <div class="container mx-auto">
            <div class="mb-10">
                <p
                    class="text-xs font-mono tracking-[0.2em] uppercase text-gray-400 mb-2"
                >
                    Architecture
                </p>
                <h2 class="text-3xl font-bold font-dotgothic16">
                    Conversational RAG
                </h2>
            </div>
            <div class="flex flex-col lg:flex-row gap-16 items-center">
                <ConversationalRetrievalChain client:load />
                <div class="flex flex-col gap-7 lg:max-w-sm">
                    <div>
                        <p
                            class="text-[11px] font-mono tracking-[0.15em] uppercase text-orange-400 mb-2"
                        >
                            history_aware_retriever
                        </p>
                        <p class="text-sm leading-relaxed">
                            Using LangChain we create a flow where you can
                            converse with the video (transcript) and it includes
                            memory. It remembers things already discussed
                            because it's a conversation.
                        </p>
                    </div>
                    <div
                        class="h-px bg-linear-to-r from-gray-600 to-transparent"
                    >
                    </div>
                    <div>
                        <p
                            class="text-[11px] font-mono tracking-[0.15em] uppercase text-blue-400 mb-2"
                        >
                            question_answer_chain
                        </p>
                        <p class="text-sm leading-relaxed">
                            Through configuration you can adjust different
                            parameters such as the models to use at each step.
                            Allowing fine-grained control over your budget and
                            usage style.
                        </p>
                    </div>
                </div>
            </div>
            <div class="mt-20">
                <div class="flex flex-col lg:flex-row gap-12 lg:items-stretch">
                    <!-- Left: header + diagram stacked -->
                    <div class="shrink-0 flex flex-col">
                        <div class="mb-8">
                            <p
                                class="text-xs font-mono tracking-[0.2em] uppercase text-gray-400 mb-2"
                            >
                                Retrieval
                            </p>
                            <h2 class="text-3xl font-bold font-dotgothic16">
                                Hybrid Search
                            </h2>
                        </div>
                        <HybridSearchDiagram client:load />
                    </div>
                    <!-- Right: spreads to fill the diagram's height -->
                    <div class="flex-1 flex flex-col justify-center gap-6">
                        <!-- Top: BM25 + lancedb side by side -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:divide-x divide-gray-800">
                            <div>
                                <p
                                    class="text-[11px] font-mono tracking-[0.15em] uppercase text-pink-400 mb-3"
                                >
                                    BM25 — Sparse Retriever
                                </p>
                                <p class="text-sm leading-relaxed text-gray-300">
                                    Keyword search: enter a word or phrase and
                                    it focuses on exact or closely related
                                    terms. High precision for literal matches.
                                </p>
                            </div>
                            <div class="md:pl-6">
                                <p
                                    class="text-[11px] font-mono tracking-[0.15em] uppercase text-blue-400 mb-3"
                                >
                                    lancedb — Dense Retriever
                                </p>
                                <p class="text-sm leading-relaxed text-gray-300">
                                    Vector search by semantic meaning: even if
                                    the words don't match exactly, if the
                                    meaning is relevant the document will be
                                    retrieved.
                                </p>
                            </div>
                        </div>
                        <!-- Floating separator -->
                        <div
                            class="h-px bg-linear-to-r from-gray-600 to-transparent"
                        >
                        </div>
                        <!-- Bottom: Ensemble pushed to bottom -->
                        <div>
                            <p
                                class="text-[11px] font-mono tracking-[0.15em] uppercase text-green-400 mb-3"
                            >
                                Ensemble — The best of both
                            </p>
                            <p class="text-sm leading-relaxed text-gray-300">
                                Combines the results of both retrievers by
                                weighting their scores. The LLM receives the
                                most relevant documents and generates responses
                                with greater coverage and precision.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="-mt-16 py-20 bg-center bg-cover bg-no-repeat bg-color-morph">
            <div class="container mx-auto">
                <div class="max-w-4xl mx-auto">
                    <div style="padding:56.25% 0 0 0;position:relative;">
                        <iframe
                            src="https://player.vimeo.com/video/1142613066?h=158078da09&badge=0&autopause=0&player_id=0&app_id=58479&autoplay=1&muted=1"
                            allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
                            style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;"
                            title="youtube-briefer"></iframe>
                    </div><script src="https://player.vimeo.com/api/player.js"></script>
                </div>
            </div>
        </div>
    </section>
</Layout>
